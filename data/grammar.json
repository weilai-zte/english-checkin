[
  {
    "id": "be_verb",
    "title": "Be 动词（am/is/are）的用法",
    "level": "初一上",
    "规则": "主语 + be动词 + 表语",
    "am_is_are": {
      "I": "am",
      "He/She/It": "is",
      "You/We/They": "are"
    },
    "例子": [
      {
        "句": "I am a student.",
        "翻译": "我是一名学生。"
      },
      {
        "句": "She is tall.",
        "翻译": "她很高。"
      },
      {
        "句": "They are in the classroom.",
        "翻译": "他们在教室里。"
      }
    ],
    "练习": [
      {
        "题": "My name ____ Li Ming.",
        "答案": "is",
        "提示": "My name是第三人称单数"
      },
      {
        "题": "I ____ from China.",
        "答案": "am",
        "提示": "I用am"
      },
      {
        "题": "You and I ____ friends.",
        "答案": "are",
        "提示": "You和I都是复数概念"
      }
    ]
  },
  {
    "id": "present_simple",
    "title": "一般现在时",
    "level": "初一上",
    "规则": "主语 + 动词原形/动词-s/es（第三人称单数）",
    "知识点": {
      "第三人称单数": "在He/She/It后，动词加-s或-es",
      "规则": {
        "一般动词": "加 -s（plays, reads）",
        "以s/x/o/ch/sh结尾": "加 -es（watches, goes）",
        "辅音+y结尾": "y变i加-es（study→studies）"
      }
    },
    "例子": [
      {
        "句": "I play football every day.",
        "翻译": "我每天都踢足球。"
      },
      {
        "句": "She plays football every day.",
        "翻译": "她每天都踢足球。"
      }
    ],
    "练习": [
      {
        "题": "He ____ (watch) TV every day.",
        "答案": "watches",
        "提示": "He第三人称单数，watch加es"
      },
      {
        "题": "They ____ (like) apples.",
        "答案": "like",
        "提示": "They复数不加s"
      },
      {
        "题": "My mother ____ (cook) dinner.",
        "答案": "cooks",
        "提示": "母亲是第三人称单数"
      }
    ]
  },
  {
    "id": "present_continuous",
    "title": "现在进行时",
    "level": "初一下",
    "规则": "主语 + am/is/are + 动词-ing",
    "知识点": {
      "构成": {
        "be动词": "am(I) / is(He/She/It) / are(You/We/They)",
        "动词ing": "原形+ing（doing）"
      },
      "规则": {
        "一般情况": "加-ing（playing）",
        "以e结尾": "去e加-ing（making）",
        "重读闭音节结尾": "双写尾字母加-ing（running）"
      }
    },
    "例子": [
      {
        "句": "I am reading a book now.",
        "翻译": "我现在正在读书。"
      },
      {
        "句": "She is cooking dinner.",
        "翻译": "她正在做晚饭。"
      }
    ],
    "练习": [
      {
        "题": "Look! The baby ____ (cry).",
        "答案": "is crying",
        "提示": "look表示现在进行时"
      },
      {
        "题": "I ____ (listen) to music.",
        "答案": "am listening",
        "提示": "I用am"
      },
      {
        "题": "He ____ (make) a cake.",
        "答案": "is making",
        "提示": "make去e加ing"
      }
    ]
  },
  {
    "id": "past_simple",
    "title": "一般过去时",
    "level": "初一下",
    "规则": "主语 + 动词过去式",
    "知识点": {
      "规则动词": {
        "一般情况": "加-ed（played）",
        "以e结尾": "加-d（liked）",
        "辅音+y结尾": "y变i加-ed（studied）",
        "重读闭音节结尾": "双写尾字母加-ed（stopped）"
      },
      "be动词过去式": "was(I/He/She/It) / were(You/We/They)"
    },
    "例子": [
      {
        "句": "I played football yesterday.",
        "翻译": "我昨天踢足球了。"
      },
      {
        "句": "She was happy last night.",
        "翻译": "她昨晚很开心。"
      }
    ],
    "练习": [
      {
        "题": "I ____ (visit) my grandmother last week.",
        "答案": "visited",
        "提示": "last week一般过去时"
      },
      {
        "题": "He ____ (be) very tired yesterday.",
        "答案": "was",
        "提示": "yesterday用过去式was"
      },
      {
        "题": "They ____ (go) home after school.",
        "答案": "went",
        "提示": "go的过去式是went"
      }
    ]
  },
  {
    "id": "prepositions",
    "title": "常用介词",
    "level": "初一上",
    "规则": "介词 + 名词/代词，构成介词短语",
    "知识点": {
      "时间介词": {
        "at": "时刻（at 7 o'clock）/ 节日（at Christmas）",
        "on": "具体日期（on Monday）/ 星期（on Tuesday）",
        "in": "月份（in January）/ 年份（in 2024）/ 季节（in spring）"
      },
      "地点介词": {
        "in": "在…里面（in the room）",
        "on": "在…上面（on the table）",
        "at": "在…地点（at school/home）",
        "under": "在…下面（under the chair）",
        "near": "在…附近（near the window）",
        "behind": "在…后面（behind the door）"
      },
      "方位介词": {
        "to": "到…（go to school）",
        "from": "从…（from China）",
        "with": "和…一起（with my friends）",
        "for": "为了…（for breakfast）",
        "by": "通过…方式（by bus）"
      }
    },
    "例子": [
      {
        "句": "I get up at 6 o'clock.",
        "翻译": "我6点起床。"
      },
      {
        "句": "My birthday is in July.",
        "翻译": "我的生日在七月。"
      }
    ],
